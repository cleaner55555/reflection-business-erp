generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ MULTI-TENANT: KOMPANIJE ============

model Company {
  id            String   @id @default(cuid())
  name          String
  pib           String?  @unique
  maticniBr     String?
  address       String?
  city          String?
  zipCode       String?
  phone         String?
  email         String?
  website       String?
  logo          String?
  bankName      String?
  bankAccount   String?
  isActive      Boolean  @default(true)
  plan          String   @default("free") // free, starter, pro, enterprise
  trialEndsAt   DateTime?
  maxUsers      Int      @default(5)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         UserCompany[]
  apiKeys       ApiKey[]

  partners            Partner[]
  products            Product[]
  invoices            Invoice[]
  recurringInvoices   RecurringInvoice[]
  purchaseOrders      PurchaseOrder[]
  deliveryNotes       DeliveryNote[]
  stockMovements      StockMovement[]
  priceLists          PriceList[]
  transactions        Transaction[]
  cashRegisters       CashRegister[]
  contacts            Contact[]
  restoOrderItems     RestoOrderItem[]
  deals               Deal[]
  crmActivities       CrmActivity[]
  calendarEvents      CalendarEvent[]
  employees           Employee[]
  payrolls            Payroll[]
  attendances         Attendance[]
  assets              Asset[]
  accounts            Account[]
  journalEntries      JournalEntry[]
  protocolEntries     ProtocolEntry[]
  courses             Course[]
  lessons             Lesson[]
  vehicles            Vehicle[]
  vehicleServices     VehicleService[]
  vehicleExpenses     VehicleExpense[]
  projects            Project[]
  projectTasks        ProjectTask[]
  documents           Document[]
  rentalVehicles      RentalVehicle[]
  rentals             Rental[]
  restoCategories     RestoCategory[]
  restoMenuItems      RestoMenuItem[]
  restoTables         RestoTable[]
  restoOrders         RestoOrder[]
  emailLists          EmailList[]
  emailSubscribers    EmailSubscriber[]
  emailCampaigns      EmailCampaign[]
  emailTemplates      EmailTemplate[]
  integrationJobs     IntegrationJob[]
  syncConnectors      SyncConnector[]
  syncLogs            SyncLog[]
  notifications       Notification[]
  bankAccounts        BankAccount[]
  bankTransactions    BankTransaction[]
  appSettings         AppSetting[]
}

// ============ USER ACCOUNTS & ROLES ============

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  firstName     String
  lastName      String
  avatar        String?
  phone         String?
  isActive      Boolean  @default(true)
  isSuperAdmin  Boolean  @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyRoles  UserCompany[]
  ownedApiKeys  ApiKey[]      @relation("ApiKeyOwner")
  createdJobs   IntegrationJob[]  @relation("JobCreator")
}

model Role {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String
  description   String?
  permissions   String   // JSON: { "invoices": ["read","write","delete"], "partners": ["read","write"], ... }
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userCompanies UserCompany[]
}

model UserCompany {
  id            String   @id @default(cuid())
  userId        String
  companyId     String
  roleId        String
  jobTitle      String?
  isDefault     Boolean  @default(false) // is this their default company?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role          Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, companyId])
}

model ApiKey {
  id            String   @id @default(cuid())
  name          String
  key           String   @unique
  companyId     String
  userId        String
  permissions   String   @default("[\"read\"]") // JSON: ["read","write"] or specific scopes
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User     @relation("ApiKeyOwner", fields: [userId], references: [id], onDelete: Cascade)
}

// ============ PARTNERI / KLIJENTI / DOBAVLJAČI ============

model Partner {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  pib           String?
  maticniBr     String?
  address       String?
  city          String?
  zipCode       String?
  phone         String?
  email         String?
  type          String   @default("kupac") // kupac, dobavljac, partner
  account       String?
  bank          String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id])
  invoices             Invoice[]
  recurringInvoices   RecurringInvoice[]
  purchaseOrders       PurchaseOrder[]
  deliveryNotes        DeliveryNote[]
  contacts             Contact[]
  deals                Deal[]
  employees            Employee[]
  documents            Document[]

  @@unique([companyId, pib])
}

// ============ ROBA / PROIZVODI ============

model Product {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  sku           String
  barcode       String?
  category      String?
  unit          String   @default("kom") // kom, kg, l, m, pak
  purchasePrice Float
  sellingPrice  Float
  minStock      Int      @default(0)
  currentStock  Int      @default(0)
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id])
  invoiceItems       InvoiceItem[]
  purchaseOrderItems PurchaseOrderItem[]
  stockMovements     StockMovement[]
  deliveryNoteItems  DeliveryNoteItem[]
  priceListItems     PriceListItem[]

  @@unique([companyId, sku])
}

// ============ FAKTURE ============

model Invoice {
  id            String   @id @default(cuid())
  companyId     String
  number        String
  date          DateTime @default(now())
  dueDate       DateTime
  partnerId     String
  status        String   @default("nacrt") // nacrt, poslata, placena, otkazana
  type          String   @default("izlazna") // izlazna, ulazna, predracun
  totalAmount   Float
  taxAmount     Float    @default(0)
  discountPct   Float    @default(0)
  notes         String?
  paymentMethod String   @default("racun") // racun, gotovina, kartica
  sefStatus     String   @default("not_sent") // not_sent, sent, accepted, rejected
  sefSentAt     DateTime?
  sefUuid       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id])
  partner       Partner  @relation(fields: [partnerId], references: [id])
  items         InvoiceItem[]
  recurringId   String?
  recurring     RecurringInvoice? @relation(fields: [recurringId], references: [id])
  bankTransactions BankTransaction[]

  @@unique([companyId, number])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String
  productName String
  quantity    Float
  unitPrice   Float
  discountPct Float    @default(0)
  taxRate     Float    @default(20)
  total       Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ============ PONAVLJAjuCE FAKTURE ============

model RecurringInvoice {
  id              String       @id @default(cuid())
  companyId       String
  name            String
  partnerId       String
  frequency       String       // monthly, weekly, quarterly, yearly
  nextDate        DateTime     // when to generate next invoice
  lastGenerated   DateTime?
  startDate       DateTime     // when recurrence starts
  endDate         DateTime?    // optional end date
  isActive        Boolean      @default(true)
  items           String       // JSON array of invoice line items template
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  company         Company      @relation(fields: [companyId], references: [id])
  partner         Partner      @relation(fields: [partnerId], references: [id])
  invoices        Invoice[]
}

// ============ NABAVKA ============

model PurchaseOrder {
  id            String   @id @default(cuid())
  companyId     String
  number        String
  date          DateTime @default(now())
  partnerId     String
  status        String   @default("nacrt") // nacrt, poslata, primljena, otkazana
  totalAmount   Float
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id])
  partner       Partner  @relation(fields: [partnerId], references: [id])
  items         PurchaseOrderItem[]

  @@unique([companyId, number])
}

model PurchaseOrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Float
  unitPrice   Float
  total       Float

  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ============ MAGACIN / ZALIHE ============

model StockMovement {
  id          String   @id @default(cuid())
  companyId   String
  productId   String
  date        DateTime @default(now())
  type        String   // prijem, izdavanje, inventura, korekcija
  quantity    Float
  documentRef String?
  notes       String?
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

// ============ OTPREMNICE ============

model DeliveryNote {
  id            String   @id @default(cuid())
  companyId     String
  number        String
  date          DateTime @default(now())
  partnerId     String
  status        String   @default("nacrt") // nacrt, pripremljena, otpremljena, stornirana
  invoiceNumber String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id])
  partner       Partner  @relation(fields: [partnerId], references: [id])
  items         DeliveryNoteItem[]

  @@unique([companyId, number])
}

model DeliveryNoteItem {
  id              String   @id @default(cuid())
  deliveryNoteId  String
  productId       String
  productName     String
  quantity        Float
  unitPrice       Float

  deliveryNote DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  product       Product @relation(fields: [productId], references: [id])
}

// ============ CENOVNICI ============

model PriceList {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  validFrom   DateTime?
  validTo     DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  items   PriceListItem[]
}

model PriceListItem {
  id          String   @id @default(cuid())
  priceListId String
  productId   String
  price       Float
  discountPct Float    @default(0)

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
}

// ============ FINANSIJE ============

model Transaction {
  id            String   @id @default(cuid())
  companyId     String
  date          DateTime @default(now())
  type          String   // prihod, rashod
  category      String   // promet, nabavka, plata, režije, ostalo
  amount        Float
  description   String
  documentRef   String?
  partnerId     String?
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
}

// ============ KASA ============

model CashRegister {
  id            String   @id @default(cuid())
  companyId     String
  date          DateTime @default(now())
  type          String   // ulaz, izlaz
  amount        Float
  description   String
  partnerName   String?
  paymentMethod String   @default("gotovina")
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
}

// ============ CRM - KONTAKTI ============

model Contact {
  id          String   @id @default(cuid())
  companyId   String
  firstName   String
  lastName    String
  email       String?
  phone       String?
  position    String?
  companyName String?
  partnerId   String?
  notes       String?
  tags        String?
  isClient    Boolean  @default(false)
  isSupplier  Boolean  @default(false)
  isLead      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id])
  partner       Partner?       @relation(fields: [partnerId], references: [id])
  activities    CrmActivity[]
  deals         Deal[]
}

// ============ CRM - POSLOVNE PRILIKE ============

model Deal {
  id          String   @id @default(cuid())
  companyId   String
  title       String
  value       Float    @default(0)
  stage       String   @default("lead") // lead, kvalifikacija, predlog, pregovaranje, won, lost
  probability Int      @default(10)
  score       Int      @default(0)
  source      String   @default("manual") // manual, web, referral, cold_call, email, social, trade_show, advertising, other
  lostReason  String?
  tags        String?  // JSON array of tags
  contactId   String?
  partnerId   String?
  assignedTo  String?
  expectedRevenue Float @default(0)
  closeDate   DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id])
  contact   Contact? @relation(fields: [contactId], references: [id])
  partner   Partner? @relation(fields: [partnerId], references: [id])
  activities CrmActivity[]
}

// ============ CRM - AKTIVNOSTI ============

model CrmActivity {
  id          String   @id @default(cuid())
  companyId   String
  type        String   // poziv, sastanak, email, task, napomena
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean  @default(false)
  contactId   String?
  dealId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id])
  deal    Deal?    @relation(fields: [dealId], references: [id])
}

// ============ KALENDAR ============

model CalendarEvent {
  id          String   @id @default(cuid())
  companyId   String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  allDay      Boolean  @default(false)
  color       String   @default("primary")
  type        String   @default("sastanak")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ============ PLATE I KADROVI ============

model Employee {
  id            String   @id @default(cuid())
  companyId     String
  firstName     String
  lastName      String
  email         String?
  phone         String?
  position      String?
  department    String?
  baseSalary    Float    @default(0)
  bankAccount   String?
  partnerId     String?  // ako je iznajmljen/vanradni
  isActive      Boolean  @default(true)
  hireDate      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id])
  partner   Partner? @relation(fields: [partnerId], references: [id])
  payrolls  Payroll[]
  attendances Attendance[]
}

model Payroll {
  id            String   @id @default(cuid())
  companyId     String
  employeeId    String
  month         Int      // 1-12
  year          Int
  baseSalary    Float
  bonuses       Float    @default(0)
  deductions    Float    @default(0)
  netSalary     Float
  status        String   @default("nacrt") // nacrt, odobreno, isplaceno
  payDate       DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}

model Attendance {
  id            String   @id @default(cuid())
  companyId     String
  employeeId    String
  date          DateTime
  hoursWorked   Float    @default(8)
  type          String   @default("rad") // rad, bolovanje, godisnji, sluzbeni_put, odsustvo
  notes         String?
  createdAt     DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}

// ============ OSNOVNA SREDSTVA ============

model Asset {
  id                  String   @id @default(cuid())
  companyId           String
  name                String
  category            String?
  serialNumber        String?
  purchaseDate        DateTime @default(now())
  purchasePrice       Float
  currentValue        Float
  depreciation        Float    @default(0)
  usefulLife          Int      @default(60) // meseci
  depreciationMethod  String   @default("linearna") // linearna, degresivna
  location            String?
  status              String   @default("aktivno") // aktivno, na_popravci, izvan_upotrebe, prodato, otpisano
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ============ KNJIGOVODSTVO ============

model Account {
  id          String   @id @default(cuid())
  companyId   String
  code        String   // npr. 020, 110, 200...
  name        String
  type        String   @default("aktivna") // aktivna, pasivna, prihodka, rashodna, kontna
  description String?
  parentCode  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  entries  JournalEntry[]
}

model JournalEntry {
  id            String   @id @default(cuid())
  companyId     String
  date          DateTime @default(now())
  accountId     String
  debit         Float    @default(0)
  credit        Float    @default(0)
  description   String
  documentRef   String?
  partnerId     String?
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  account Account @relation(fields: [accountId], references: [id])
}

// ============ PROTOKOL ============

model ProtocolEntry {
  id            String   @id @default(cuid())
  companyId     String
  number        String
  date          DateTime @default(now())
  direction     String   @default("ulaz") // ulaz, izlaz
  sender        String?  // pošiljalac (za ulazne)
  recipient     String?  // primalac (za izlazne)
  subject       String
  description   String?
  documentType  String?  // pismo, ugovor, ponuda, račun, ostalo
  dueDate       DateTime?
  responsible   String?
  status        String   @default("primljen") // primljen, u_radu, završen, proslijeđen, odgovoren
  priority      String   @default("srednji") // nizak, srednji, visok, hitan
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, number])
}

// ============ LMS - MODUL ZA UČENJE ============

model Course {
  id            String   @id @default(cuid())
  companyId     String
  title         String
  description   String?
  category      String?
  instructor    String?
  duration      Int      @default(0)  // minuta
  status        String   @default("aktivno") // aktivno, skript, arhiviran
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  lessons Lesson[]
}

model Lesson {
  id            String   @id @default(cuid())
  companyId     String
  courseId      String
  title         String
  content       String?  // HTML sadržaj
  orderNum      Int      @default(0)
  type          String   @default("tekst") // tekst, video, test, dok
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// ============ VOZNI PARK ============

model Vehicle {
  id            String   @id @default(cuid())
  companyId     String
  registration  String   // registarski broj
  make          String   // marka
  model         String   // model
  year          Int
  fuelType      String   @default("dizel") // dizel, benzin, gas, hibrid, električni
  mileage       Int      @default(0)
  status        String   @default("aktivno") // aktivno, na_servisu, u_garazi, prodato
  assignedTo    String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company  Company         @relation(fields: [companyId], references: [id])
  services VehicleService[]
  expenses VehicleExpense[]

  @@unique([companyId, registration])
}

model VehicleService {
  id            String   @id @default(cuid())
  companyId     String
  vehicleId     String
  date          DateTime @default(now())
  type          String   @default("servis") // servis, promjena_ulja, gume, tehnicki, registracija
  description   String
  cost          Float    @default(0)
  mileage       Int
  nextDue       DateTime?
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model VehicleExpense {
  id            String   @id @default(cuid())
  companyId     String
  vehicleId     String
  date          DateTime @default(now())
  type          String   @default("gorivo") // gorivo, putarina, parking, servis, ostalo
  amount        Float
  description   String
  mileage       Int      @default(0)
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

// ============ PROJEKTI ============

model Project {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  status      String   @default("aktivan") // aktivan, zavrsen, pauziran, otkazan
  startDate   DateTime @default(now())
  endDate     DateTime?
  budget      Float    @default(0)
  spent       Float    @default(0)
  priority    String   @default("srednji") // nizak, srednji, visok, hitan
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  tasks   ProjectTask[]
}

model ProjectTask {
  id          String   @id @default(cuid())
  companyId   String
  projectId   String
  title       String
  description String?
  status      String   @default("todo") // todo, u_toku, zavrseno, blokirano
  priority    String   @default("srednji")
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============ DMS - DOKUMENTI ============

model Document {
  id          String   @id @default(cuid())
  companyId   String
  title       String
  category    String?
  type        String?  // faktura, ugovor, ponuda, izvestaj, ostalo
  fileName    String?
  fileSize    Int      @default(0)
  status      String   @default("aktivno")
  partnerId   String?
  expiresAt   DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  partner Partner? @relation(fields: [partnerId], references: [id])
}

// ============ RENT A CAR ============

model RentalVehicle {
  id            String   @id @default(cuid())
  companyId     String
  name          String   // npr. VW Golf 8
  make          String
  model         String
  year          Int
  registration  String   // registarski broj
  fuelType      String   @default("dizel")
  transmission  String   @default("automatski") // automatski,manuelni
  seats         Int      @default(5)
  dailyRate     Float    // dnevna cena RSD
  weeklyRate    Float?
  monthlyRate   Float?
  mileage       Int      @default(0)
  status        String   @default("dostupno") // dostupno, iznajmljeno, na_servisu, rezervisano, prodato
  ac            Boolean  @default(true)
  gps           Boolean  @default(false)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  rentals Rental[]

  @@unique([companyId, registration])
}

model Rental {
  id            String   @id @default(cuid())
  companyId     String
  number        String
  vehicleId     String
  clientName    String
  clientPhone   String?
  clientEmail   String?
  clientIdDoc   String?  // broj lične karte
  startDate     DateTime
  endDate       DateTime
  pickupMileage Int
  returnMileage Int?
  dailyRate     Float
  totalDays     Int
  totalAmount   Float
  deposit       Float    @default(0)
  status        String   @default("rezervacija") // rezervacija, aktivna, zavrsena, otkazana
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id])
  vehicle RentalVehicle @relation(fields: [vehicleId], references: [id])

  @@unique([companyId, number])
}

// ============ KAFE RESTORAN ============

model RestoCategory {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  items   RestoMenuItem[]
}

model RestoMenuItem {
  id            String   @id @default(cuid())
  companyId     String
  categoryId    String
  name          String
  description   String?
  price         Float
  cost          Float    @default(0) // nabavna cena
  image         String?
  isAvailable   Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company  Company        @relation(fields: [companyId], references: [id])
  category RestoCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems RestoOrderItem[]
}

model RestoTable {
  id          String   @id @default(cuid())
  companyId   String
  number      Int
  name        String?  // npr. "Terasa 1"
  capacity    Int      @default(4)
  status      String   @default("slobodan") // slobodan, zauzet, rezervisan
  location    String?  // npr. "sprat", "terasa", "bašta"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  orders  RestoOrder[]

  @@unique([companyId, number])
}

model RestoOrder {
  id            String   @id @default(cuid())
  companyId     String
  orderNumber   Int
  tableId       String?
  status        String   @default("u_toku") // u_toku, spremno, usluženo, plaćeno, otkazano
  type          String   @default("restoran") // restoran, porudzbina, dostava
  totalAmount   Float    @default(0)
  discountPct   Float    @default(0)
  waiter        String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id])
  table   RestoTable?   @relation(fields: [tableId], references: [id])
  items   RestoOrderItem[]
}

model RestoOrderItem {
  id            String   @id @default(cuid())
  companyId     String
  orderId       String
  menuItemId    String
  menuItemName  String
  quantity      Int
  unitPrice     Float
  total         Float
  notes         String?
  status        String   @default("naručeno") // naručeno, u_pripremi, spremno, usluženo

  company  Company      @relation(fields: [companyId], references: [id])
  order    RestoOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem RestoMenuItem @relation(fields: [menuItemId], references: [id])
}

// ============ MAILERLITE - EMAIL MARKETING ============

model EmailList {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company     Company          @relation(fields: [companyId], references: [id])
  subscribers EmailSubscriber[]
  campaigns   EmailCampaign[]
}

model EmailSubscriber {
  id            String   @id @default(cuid())
  companyId     String
  listId        String?
  email         String
  firstName     String?
  lastName      String?
  status        String   @default("aktivan") // aktivan, neaktivan, otkazan
  source        String?  // web forma, uvoz, ručno
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company    @relation(fields: [companyId], references: [id])
  list   EmailList?  @relation(fields: [listId], references: [id])
}

model EmailCampaign {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  subject       String
  preheader     String?
  content       String   // HTML sadržaj
  status        String   @default("nacrt") // nacrt, poslata, zakazana, u_toku, zavrsena
  listId        String?
  sentCount     Int      @default(0)
  openRate      Float    @default(0) // procenta
  clickRate     Float    @default(0)
  bounceRate    Float    @default(0)
  scheduledAt   DateTime?
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company   @relation(fields: [companyId], references: [id])
  list   EmailList? @relation(fields: [listId], references: [id])
}

model EmailTemplate {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  subject       String
  content       String   // HTML
  category      String?  // promotivno, transakciono, obavestenje
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ============ INTEGRACIJE ============

model IntegrationJob {
  id            String   @id @default(cuid())
  companyId     String
  type          String   // import, export
  entityType    String   // partners, products, transactions, contacts, invoices, stock
  source        String   @default("custom") // biznis_navigator, pantheon, minimax, eFakture, custom
  status        String   @default("pending") // pending, processing, completed, failed, partial
  totalRows     Int      @default(0)
  successRows   Int      @default(0)
  failedRows    Int      @default(0)
  errors        String?  // JSON array of error details
  fileName      String?
  mapping       String?  // JSON: { sourceCol: targetField }
  options       String?  // JSON: skipDuplicates, updateExisting, etc.
  notes         String?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  creator User?  @relation("JobCreator", fields: [createdBy], references: [id])
}

// ============ SYNC CONNECTORS ============

model SyncConnector {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  type            String   // biznis_navigator, pantheon, minimax, efakture, sap, biznisoft, custom_api
  direction       String   @default("import") // import, export, bidirectional
  isActive        Boolean  @default(false)
  status          String   @default("disconnected") // disconnected, connected, syncing, error
  hostUrl         String?
  apiKey          String?
  username        String?
  password        String?
  database        String?
  syncInterval    Int      @default(60) // minutes between auto-syncs
  syncEntities    String   // JSON array: ["partners","products"]
  fieldMapping    String?
  lastSyncAt      DateTime?
  lastSyncStatus  String?
  totalSyncs      Int      @default(0)
  totalRecords    Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company  @relation(fields: [companyId], references: [id])
  logs   SyncLog[]
}

model SyncLog {
  id              String   @id @default(cuid())
  companyId       String
  connectorId     String
  direction       String
  entityType      String
  status          String
  totalRecords    Int      @default(0)
  successRecords  Int      @default(0)
  failedRecords   Int      @default(0)
  errors          String?
  duration        Int      @default(0)
  triggerType     String   @default("auto")
  notes           String?
  createdAt       DateTime @default(now())

  company   Company      @relation(fields: [companyId], references: [id])
  connector SyncConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
}

// ============ NOTIFICATIONS ============

model Notification {
  id          String   @id @default(cuid())
  companyId   String
  userId      String?  // null = broadcast to all users in company
  type        String   // overdue_invoice, low_stock, payment_received, task_due, system
  title       String
  message     String
  entityType  String?  // invoice, product, partner, etc.
  entityId    String?
  isRead      Boolean  @default(false)
  priority    String   @default("medium") // low, medium, high, urgent
  actionUrl   String?  // which module to open (e.g., "fakture")
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
}

// ============ BANKA - SINHRONIZACIJA I PREKNJIŽAVANJE ============

model BankAccount {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  bank          String?
  account       String
  currency      String   @default("RSD")
  isActive      Boolean  @default(true)
  balance       Float    @default(0)
  lastSyncAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company      Company          @relation(fields: [companyId], references: [id])
  transactions BankTransaction[]
}

model BankTransaction {
  id            String   @id @default(cuid())
  companyId     String
  bankAccountId String
  date          DateTime
  amount        Float
  description   String
  reference     String?
  counterpart   String?
  category      String?
  isReconciled  Boolean  @default(false)
  invoiceId     String?
  transactionId String?
  createdAt     DateTime @default(now())

  company     Company      @relation(fields: [companyId], references: [id])
  bankAccount BankAccount  @relation(fields: [bankAccountId], references: [id])
  invoice     Invoice?     @relation(fields: [invoiceId], references: [id])
}

// ============ SETTINGS ============

model AppSetting {
  id          String   @id @default(cuid())
  companyId   String?
  key         String
  label       String?
  value       String
  type        String   @default("text") // text, boolean, number, json
  group       String   @default("general") // general, modules, company
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id])

  @@unique([companyId, key])
}
