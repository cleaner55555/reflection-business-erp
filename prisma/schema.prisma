// ============ MAGACIN / ZALIHE ============

model WarehouseLocation {
  id          String   @id @default(cuid())
  companyId   String
  name        String   // npr. "Regal A", "Hala 1 - Polica 3"
  code        String   @unique // npr. "WH-A-03"
  type        String   @default("polica") // magacin, zona, regal, polica, bin
  zone        String   @default("skladistenje") // prijem, skladistenje, otprema, kontrola, hladjenje, return, karantin
  row         Int      @default(0) // red za vizuelnu mapu
  col         Int      @default(0) // kolona za vizuelnu mapu
  capacity    Float    @default(0) // kapacitet lokacije
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company       Company              @relation(fields: [companyId], references: [id])
  parent        WarehouseLocation?   @relation("LocationTree", fields: [parentId], references: [id])
  children      WarehouseLocation[] @relation("LocationTree")
  stockMovements StockMovement[] @relation("MovementLocation")
  movementsTo   StockMovement[] @relation("MovementToLocation")
  lots          Lot[]
  inventoryCounts InventoryCount[]
}

model StockMovement {
  id            String    @id @default(cuid())
  companyId     String
  productId     String
  locationId    String?
  toLocationId  String? // za transfere između lokacija
  date          DateTime  @default(now())
  type          String    // prijem, izdavanje, inventura, korekcija, transfer
  quantity      Float
  unitCost      Float     @default(0) // nabavna cena u trenutku kretanja
  lotNumber     String?   // lot/batch broj
  expiryDate    DateTime? // rok trajanja
  documentRef   String?
  notes         String?
  createdAt     DateTime  @default(now())

  company       Company            @relation(fields: [companyId], references: [id])
  product       Product            @relation(fields: [productId], references: [id])
  location      WarehouseLocation? @relation("MovementLocation", fields: [locationId], references: [id])
  toLocation   WarehouseLocation? @relation("MovementToLocation", fields: [toLocationId], references: [id])
}

// ============ OTPREMNICE ============

model DeliveryNote {
  id            String   @id @default(cuid())
  companyId     String
  number        String
  date          DateTime @default(now())
  partnerId     String
  status        String   @default("nacrt") // nacrt, pripremljena, otpremljena, stornirana
