// ============ PLATE I KADROVI ============

model Employee {
  id            String   @id @default(cuid())
  companyId     String
  firstName     String
  lastName      String
  email         String?
  phone         String?
  position      String?
  department    String?
  baseSalary    Float    @default(0)
  bankAccount   String?
  partnerId     String?  // ako je iznajmljen/vanradni
  managerId     String?  // nadređeni (za organigram)
  contractType  String   @default("odredjeno") // odredjeno, neodredjeno, stipendija, honorarno, praksa
  contractEndDate DateTime? // kraj ugovora
  benefits      String?  // JSON: { "transport": 5000, "obrok": 3000, ... }
  isActive      Boolean  @default(true)
  hireDate      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id])
  partner       Partner? @relation(fields: [partnerId], references: [id])
