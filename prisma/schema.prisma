  location        String   @default("")
  capacityPerHour Int      @default(50)
  currentLoad     Int      @default(0)
  totalHours      Int      @default(0)
  downtimeLog     String   @default("[]") // JSON: DowntimeEntry[]
  notes           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ============ VoIP - CALL LOGS ============

model VoipCallLog {
  id            String   @id @default(cuid())
  companyId     String
  direction     String   @default("inbound") // inbound, outbound, internal
  caller        String   @default("") // from
  callee        String   @default("") // to
  duration      Int      @default(0) // seconds
  extension     String   @default("")
  status        String   @default("answered") // answered, missed, voicemail
  recording     Boolean  @default(false)
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ============ VoIP - EXTENSIONS ============

model VoipExtension {
  id                 String   @id @default(cuid())
  companyId          String
  number             String
  name               String
  department         String   @default("")
  type               String   @default("Desk") // Desk, Softphone, Mobile
  status             String   @default("Offline") // Online, Busy, Away, Offline
  device             String   @default("")
  ipAddress          String   @default("")
  provisioningStatus String   @default("pending") // active, pending, inactive
  notes              String   @default("")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, number])
}


// ============ GAMIFICATION - LEADERBOARD ENTRIES ============

model GamificationLeaderboardEntry {
  id              String   @id @default(cuid())
  companyId       String
  employeeId      String   @default("")
  employeeName    String
  department      String   @default("")
  avatar          String   @default("")
  totalPoints     Int      @default(0)
  level           Int      @default(1)
  rank            Int      @default(0)
  previousRank    Int      @default(0)
  badges          Int      @default(0)
  completedGoals  Int      @default(0)
  streak          Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ============ PLM (Product Lifecycle Management) ============

model PlmProduct {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  sku             String
  category        String   @default("Elektronika")
  lifecycleStage  String   @default("concept")  // concept, design, prototype, testing, launch, production, eol
  status          String   @default("development")  // active, development, discontinued
  version         String   @default("0.1.0")
  owner           String   @default("")
  description     String   @default("")
  bomRef          String   @default("")
  revisionCount   Int      @default(0)
  revisions       String   @default("[]")  // JSON: array of revision objects
  documents       String   @default("[]")  // JSON: array of document objects
  ecrs            String   @default("[]")  // JSON: array of ECR objects
  ecos            String   @default("[]")  // JSON: array of ECO objects
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, sku])
}
