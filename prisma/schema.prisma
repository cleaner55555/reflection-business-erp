generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ MULTI-TENANT: KOMPANIJE ============

model Company {
  id            String   @id @default(cuid())
  name          String
  pib           String?  @unique
  maticniBr     String?
  address       String?
  city          String?
  zipCode       String?
  phone         String?
  email         String?
  website       String?
  logo          String?
  bankName      String?
  bankAccount   String?
  isActive      Boolean  @default(true)
  plan          String   @default("free") // free, starter, pro, enterprise
  trialEndsAt   DateTime?
  maxUsers      Int      @default(5)
  currency      String   @default("RSD")
  timezone      String   @default("Europe/Belgrade")
  locale        String   @default("sr")
  modules       String   @default("[]") // JSON: enabled modules ["crm","fakture",...]
  maxStorageMb  Int      @default(100)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         UserCompany[]
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]
  webhooks      Webhook[]

  partners            Partner[]
  products            Product[]
  invoices            Invoice[]
  recurringInvoices   RecurringInvoice[]
  purchaseOrders      PurchaseOrder[]
  deliveryNotes       DeliveryNote[]
  stockMovements      StockMovement[]
  priceLists          PriceList[]
  warehouseLocations  WarehouseLocation[]
  transactions        Transaction[]
  cashRegisters       CashRegister[]
  contacts            Contact[]
  restoOrderItems     RestoOrderItem[]
  deals               Deal[]
  crmActivities       CrmActivity[]
  calendarEvents      CalendarEvent[]
  employees           Employee[]
  payrolls            Payroll[]
  attendances         Attendance[]
  assets              Asset[]
  accounts            Account[]
  journalEntries      JournalEntry[]
  protocolEntries     ProtocolEntry[]
  courses             Course[]
  lessons             Lesson[]
  vehicles            Vehicle[]
  vehicleServices     VehicleService[]
  vehicleExpenses     VehicleExpense[]
  projects            Project[]
  projectTasks        ProjectTask[]
  timesheetEntries    TimesheetEntry[]
  gamificationGoals             GamificationGoal[]
  gamificationChallenges       GamificationChallenge[]
  gamificationBadges            GamificationBadge[]
  gamificationLeaderboardEntries GamificationLeaderboardEntry[]
  documents           Document[]
  rentalVehicles      RentalVehicle[]
  rentals             Rental[]
  restoCategories     RestoCategory[]
  restoMenuItems      RestoMenuItem[]
  restoTables         RestoTable[]
  restoOrders         RestoOrder[]
  emailLists          EmailList[]
  emailSubscribers    EmailSubscriber[]
  emailCampaigns      EmailCampaign[]
  emailTemplates      EmailTemplate[]
  integrationJobs     IntegrationJob[]
  syncConnectors      SyncConnector[]
  syncLogs            SyncLog[]
  notifications       Notification[]
  bankAccounts        BankAccount[]
  bankTransactions    BankTransaction[]
  appSettings         AppSetting[]
  budgets             Budget[]
  lots                Lot[]
  inventoryCounts     InventoryCount[]
  pickWaves           PickWave[]
  receivingOrders     ReceivingOrder[]
  employeeEvaluations EmployeeEvaluation[]
  crmAutomationRules  CrmAutomationRule[]
  fiscalPeriods       FiscalPeriod[]
  posShifts           POSShift[]
  posOrders           POSOrder[] @relation("POSOrderCompany")
  shippingCarriers    ShippingCarrier[]
  shippingOrders      ShippingOrder[]
  shippingEvents      ShippingEvent[]
  salesOrders         SalesOrder[]
  subscriptions       Subscription[]
  expenseReports      ExpenseReport[]
  signingRequests     SigningRequest[]
  billOfMaterials     BillOfMaterials[]
  manufacturingOrders ManufacturingOrder[]
  qualityInspections  QualityInspection[]
  maintenanceOrders   MaintenanceOrder[]
  jobPostings         JobPosting[]
  leaveRequests       LeaveRequest[]
  referrals           Referral[]
  helpdeskTickets     HelpdeskTicket[]
  workOrders          WorkOrder[]
  appointments        Appointment[]
  planningSlots       PlanningSlot[]
  socialPosts         SocialPost[]
  smsCampaigns        SmsCampaign[]
  events              Event[]
  mktWorkflows        MktWorkflow[]
  surveys             Survey[]
  chatChannels        ChatChannel[]
  kbArticles          KbArticle[]
  webPages            WebPage[]
  blogPosts           BlogPost[]
  voipCalls           VoipCall[]
  mpVendors           MpVendor[]
  mpOrders            MpOrder[]
  mpReviews           MpReview[]
  mpDisputes          MpDispute[]
  mpProducts          MpProduct[]
  mpCoupons           MpCoupon[]
  complaints          Complaint[]
  safetyIncidents    SafetyIncident[]
  bizOrders          BizOrder[]
  classrooms         Classroom[]
  patients           Patient[]
  libraryBooks       LibraryBook[]
  homeworks          Homework[]
  standards          QualityStandard[]
  measurements       Measurement[]
  reservations        Reservation[]
  reviews             Review[]
  coupons             Coupon[]
  returnOrders        ReturnOrder[]
  deliveryOrders      DeliveryOrder[]
  payments            Payment[]
  enrollments         Enrollment[]
  tuitions            Tuition[]
  medicalRecords     MedicalRecord[]
  prescriptions      Prescription[]
  kitchenItems        KitchenItem[]
  seoPages            SeoPage[]
  properties          Property[]
  constructionSites   ConstructionSite[]
  loadingDocks        LoadingDock[]
  eventVenues         EventVenue[]
  forumTopics         ForumTopic[]
  forumCategories     ForumCategory[]
  forumTags           ForumTag[]
  transportRoutes     TransportRoute[]
  labEquipments       LabEquipment[]
  packagingOrders     PackagingOrder[]
  propertyViewings    PropertyViewing[]
  stores              Store[]
  labels              Label[]
  priceListsV2        PriceListV2[]
  customsDocs         CustomsDoc[]
  timetableEntries    TimetableEntry[]
  blueprints          Blueprint[]
  barcodeItems        BarcodeItem[]
  backupRecords       BackupRecord[]
  backupSchedules     BackupSchedule[]
  portalInvoices      PortalInvoice[]
  portalOrders        PortalOrder[]
  portalTickets       PortalTicket[]
  portalDocs          PortalDoc[]
  mfgProductionOrders  MfgProductionOrder[]
  mfgMachines         MfgMachine[]
  voipCallLogs        VoipCallLog[]
  voipExtensions      VoipExtension[]
  plmProducts          PlmProduct[]
}

// ============ NARUDŽBE (GENERALNE) ============

model BizOrder {
  id            String   @id @default(cuid())
  companyId     String
  orderNo       String
  client        String
  date          DateTime @default(now())
  deliveryDate  DateTime?
  type          String   @default("sale")    // purchase, sale, internal
  status        String   @default("pending")  // pending, confirmed, processing, shipped, delivered, cancelled
  items         Int      @default(1)
  totalAmount   Float    @default(0)
  warehouse     String?
  supplier      String?
  priority      String   @default("medium")  // low, medium, high, urgent
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, orderNo])
}

// ============ UČIONICE ============

model Classroom {
  id               String   @id @default(cuid())
  companyId        String
  name             String
  building         String
  floor            String   @default("1")
  capacity         Int      @default(30)
  currentOccupancy Int      @default(0)
  type             String   @default("lecture")     // lecture, lab, seminar, computer, workshop
  status           String   @default("available")   // available, occupied, maintenance, reserved
  equipment        String   @default("[]")
  responsible      String?
  area             Int      @default(0)
  hasProjector     Boolean  @default(false)
  hasAC            Boolean  @default(false)
  hasWhiteboard    Boolean  @default(true)
  lastInspection   DateTime?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ============ PACIJENTI ============

model Patient {
  id               String   @id @default(cuid())
  companyId        String
  patientNo        String
  firstName        String
  lastName         String
  jmbg             String?
  dateOfBirth      DateTime?
  age              Int      @default(0)
  gender           String   @default("male")
  phone            String?
  email            String?
  address          String?
  city             String?
  bloodType        String?
  insuranceNo      String?
  insuranceStatus  String   @default("active")
  primaryDoctor    String?
  status           String   @default("active")
  allergies        String   @default("[]")
  chronicConditions String   @default("[]")
  lastVisit        DateTime?
  nextAppointment  DateTime?
  totalVisits      Int      @default(0)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, patientNo])
}

// ============ BIBLIOTEKA ============

model LibraryBook {
  id               String   @id @default(cuid())
  companyId        String
  isbn             String?
  title            String
  author           String
  publisher        String?
  year             Int      @default(0)
  category         String   @default("fiction")
  totalCopies      Int      @default(1)
  availableCopies  Int      @default(1)
  borrowedCount    Int      @default(0)
  location         String?
  status           String   @default("available")
  language         String?
  pages            Int      @default(0)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ============ DOMAĆI ZADACI ============

model Homework {
  id              String   @id @default(cuid())
  companyId       String
  title           String
  subject         String
  classGroup      String?
  teacher         String?
  type            String   @default("essay")
  status          String   @default("assigned")
  dueDate         DateTime?
  assignedDate    DateTime @default(now())
  maxPoints       Int      @default(100)
  avgScore        Float    @default(0)
  submittedCount  Int      @default(0)
  totalStudents   Int      @default(0)
  description     String?
  instructions    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ============ STANDARDI KVALITETA ============

model QualityStandard {
  id            String   @id @default(cuid())
  companyId     String
  code          String
  name          String
  category      String   @default("iso")
  status        String   @default("active")
  version       String?
  issuingBody   String?
  scope         String?
  validFrom     DateTime?
  validUntil    DateTime?
  auditor       String?
  lastAudit     DateTime?
  nextAudit     DateTime?
  compliance    Int      @default(0)
  findings      String   @default("[]")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
}

// ============ MERENJA ============

model Measurement {
  id            String   @id @default(cuid())
  companyId     String
  code          String
  product       String
  parameter     String
  nominalValue  String
  unit          String
  measuredValue String
  tolerance     String
  deviation     String
  status        String   @default("pending")
  instrument    String?
  operator      String?
  station       String?
  batch         String?
  date          DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
}

// ============ REZERVACIJE (Ugostiteljstvo) ============

model Reservation {
  id              String   @id @default(cuid())
  companyId       String
  reservationNo   String
  guestName       String
  phone           String   @default("")
  email           String   @default("")
  date            String
  time            String   @default("19:00")
  partySize       Int      @default(2)
  tableNo         String   @default("")
  area            String   @default("indoor") // indoor, outdoor, terrace, vip, bar
  status          String   @default("pending") // pending, confirmed, checked_in, completed, cancelled, no_show
  occasion        String   @default("")
  specialRequests String   @default("")
  source          String   @default("phone") // phone, website, walk_in, app, email
  duration        Int      @default(90)
  deposit         Float    @default(0)
  notes           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, reservationNo])
}

// ============ RECENZIJE ============

model Review {
  id            String   @id @default(cuid())
  companyId     String
  customerName  String
  customerEmail String   @default("")
  productName   String   @default("")
  productSku    String   @default("")
  category      String   @default("")
  rating        Int      @default(5)
  title         String
  content       String   @default("")
  status        String   @default("pending") // pending, approved, rejected, flagged, responded
  source        String   @default("website") // website, email, google, social
  verified      Boolean  @default(false)
  helpful       Int      @default(0)
  notHelpful    Int      @default(0)
  responseText  String   @default("")
  respondedAt   String   @default("")
  respondedBy   String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ============ KUPONI ============

model Coupon {
  id                   String   @id @default(cuid())
  companyId            String
  code                 String
  name                 String
  description          String   @default("")
  type                 String   @default("percentage") // percentage, fixed, free_shipping, bogo, gift_card
  discountValue        Float    @default(0)
  minOrder             Float    @default(0)
  maxDiscount          Float    @default(0)
  usageLimit           Int      @default(0)
  usageCount           Int      @default(0)
  perUserLimit         Int      @default(0)
  status               String   @default("active") // active, scheduled, expired, paused, disabled
  startDate            String   @default("")
  endDate              String   @default("")
  applicableCategories String   @default("[]") // JSON array
  applicableProducts   String   @default("[]") // JSON array
  customerGroups       String   @default("[]") // JSON array
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
}

// ============ KUHINJA (Inventar) ============

model KitchenItem {
  id           String   @id @default(cuid())
  companyId    String
  name         String
  category     String   @default("ingredient") // ingredient, spice, dairy, meat, vegetable, fruit, grain, beverage, condiment, frozen, packaging
  unit         String   @default("kom")
  quantity     Float    @default(0)
  minQuantity  Float    @default(5)
  maxQuantity  Float    @default(50)
  unitPrice    Float    @default(0)
  supplier     String   @default("")
  storageArea  String   @default("")
  expiryDate   String   @default("")
  receivedDate String   @default("")
  status       String   @default("in_stock") // in_stock, low_stock, out_of_stock, expired
  allergens    String   @default("[]") // JSON array
  notes        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ============ SEO ============

model SeoPage {
  id              String   @id @default(cuid())
  companyId       String
  url             String
  title           String
  metaDescription  String   @default("")
  keywords        String   @default("")
  status          String   @default("pending") // indexed, not_indexed, pending, error
  score           Int      @default(0)
  lastCrawled     String   @default("")
  clicks          Int      @default(0)
  impressions     Int      @default(0)
  ctr             Float    @default(0)
  position        Float    @default(0)
  wordCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, url])
}

// ============ NEKRETNINE ============

model Property {
  id              String   @id @default(cuid())
  companyId       String
  propertyNo      String
  title           String
  type            String   @default("apartment")     // apartment, house, commercial, land, garage, office
  transactionType String   @default("sale")          // sale, rent, both
  status          String   @default("available")     // available, reserved, sold, rented, off_market
  address         String   @default("")
  city            String   @default("")
  neighborhood    String   @default("")
  area            Float    @default(0)
  landArea        Float    @default(0)
  price           Float    @default(0)
  pricePerSqm     Float    @default(0)
  bedrooms        Int      @default(0)
  bathrooms       Int      @default(0)
  floor           String   @default("")
  yearBuilt       Int      @default(0)
  heating         String   @default("gas")           // central, gas, electric, wood, ac, none
  furnishing      String   @default("unfurnished")   // furnished, semi_furnished, unfurnished
  parking         Boolean  @default(false)
  elevator        Boolean  @default(false)
  terrace         Boolean  @default(false)
  registered      Boolean  @default(true)
  agent           String   @default("")
  listedDate      String   @default("")
  views           Int      @default(0)
  inquiries       Int      @default(0)
  notes           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, propertyNo])
}

// ============ GRADILIŠTE ============

model ConstructionSite {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  code            String
  type            String   @default("residential")   // residential, commercial, industrial, infrastructure, renovation
  status          String   @default("planning")      // planning, excavation, foundation, structural, envelope, systems, finishing, inspection, completed, on_hold
  address         String   @default("")
  city            String   @default("")
  investor        String   @default("")
  contractor      String   @default("")
  projectManager  String   @default("")
  workers         Int      @default(0)
  budget          Float    @default(0)
  spent           Float    @default(0)
  startDate       String   @default("")
  endDate         String?  
  progress        Int      @default(0)
  area            Float    @default(0)
  floors          Int      @default(0)
  units           Int      @default(0)
  notes           String   @default("")
  tasks           String   @default("[]")          // JSON array of tasks
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
}

// ============ RAMPA ZA UTOVAR ============

model LoadingDock {
  id                    String   @id @default(cuid())
  companyId             String
  dockNumber            String
  dockType              String   @default("unloading")   // loading, unloading, both
  vehiclePlate          String   @default("")
  driverName            String   @default("")
  companyName           String   @default("")
  appointmentDate       String   @default("")
  scheduledTime         String   @default("")
  actualStart           String?  
  actualEnd             String?  
  status                String   @default("scheduled")   // scheduled, checked_in, in_progress, completed, no_show, cancelled
  cargoType             String   @default("")
  cargoWeight           Float    @default(0)
  cargoUnit             String   @default("kg")
  palletCount           Int      @default(0)
  priority              String   @default("normal")      // urgent, normal, low
  notes                 String   @default("")
  doorAssignment        String   @default("")
  handlingInstructions  String   @default("")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, dockNumber, appointmentDate, scheduledTime])
}

// ============ USER ACCOUNTS & ROLES ============

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  firstName     String
  lastName      String
  avatar        String?
  phone         String?
  isActive      Boolean  @default(true)
  isSuperAdmin  Boolean  @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyRoles  UserCompany[]
  ownedApiKeys  ApiKey[]      @relation("ApiKeyOwner")
  createdJobs   IntegrationJob[]  @relation("JobCreator")
}

model Role {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String
  description   String?
  permissions   String   // JSON: { "invoices": ["read","write","delete"], "partners": ["read","write"], ... }
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userCompanies UserCompany[]
}

model UserCompany {
  id            String   @id @default(cuid())
  userId        String
  companyId     String
  roleId        String
  jobTitle      String?
  isDefault     Boolean  @default(false) // is this their default company?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role          Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, companyId])
}

model ApiKey {
  id            String   @id @default(cuid())
  name          String
  key           String   @unique
  companyId     String
  userId        String
  permissions   String   @default("[\"read\"]") // JSON: ["read","write"] or specific scopes
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User     @relation("ApiKeyOwner", fields: [userId], references: [id], onDelete: Cascade)
}

// ============ PARTNERI / KLIJENTI / DOBAVLJAČI ============

model Partner {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  pib           String?
  maticniBr     String?
  address       String?
  city          String?
  zipCode       String?
  phone         String?
  email         String?
  website       String?
  type          String   @default("kupac") // kupac, dobavljac, partner
  account       String?
  bank          String?
  notes         String?
  creditLimit   Float    @default(0)
  paymentTerms  Int      @default(0)    // dana za plaćanje, 0 = odmah
  loyaltyPoints Int      @default(0)   // bodovi lojalnostnog programa
  kycStatus     String   @default("not_verified") // not_verified, pending, verified, rejected
  kycVerifiedAt DateTime?
  priceListId   String?  // default cenovnik za partnera
  parentId      String?
  tags          String?  // JSON array of tags
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id])
  parent        Partner? @relation("PartnerHierarchy", fields: [parentId], references: [id])
  children      Partner[] @relation("PartnerHierarchy")
  invoices             Invoice[]
  recurringInvoices   RecurringInvoice[]
  purchaseOrders       PurchaseOrder[]
  deliveryNotes        DeliveryNote[]
  contacts             Contact[]
  deals                Deal[]
  employees            Employee[]
  documents            Document[]
  projects             Project[]
  journalEntries       JournalEntry[] @relation("JournalEntryPartner")
  priceList           PriceList? @relation("PartnerPriceList", fields: [priceListId], references: [id])
  posOrders           POSOrder[] @relation("POSOrderPartner")
  receivingOrders     ReceivingOrder[] @relation("ReceivingPartner")
  shippingOrders      ShippingOrder[] @relation("ShippingPartner")
  salesOrders         SalesOrder[]
  subscriptions       Subscription[]
  helpdeskTickets     HelpdeskTicket[] @relation("TicketPartner")
  workOrders          WorkOrder[] @relation("WorkOrderPartner")
  appointments        Appointment[] @relation("AppointmentPartner")

  @@unique([companyId, pib])
}

// ============ ROBA / PROIZVODI ============

model Product {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  sku           String
  barcode       String?
  category      String?
  unit          String   @default("kom") // kom, kg, l, m, pak
  purchasePrice Float
  sellingPrice  Float
  minStock      Int      @default(0)
  maxStock      Int      @default(0)
  currentStock  Int      @default(0)
  costMethod    String   @default("prosek") // fifo, lifo, prosek
  trackLots     Boolean  @default(false) // lot/serial tracking
  expiryDays    Int      @default(0) // rok trajanja u danima
  weight        Float    @default(0) // težina u kg
  volume        Float    @default(0) // zapremina u m3
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id])
  invoiceItems       InvoiceItem[]
  purchaseOrderItems PurchaseOrderItem[]
  stockMovements     StockMovement[]
  deliveryNoteItems  DeliveryNoteItem[]
  priceListItems     PriceListItem[]
  lots               Lot[]
  posOrderLines      POSOrderLine[]

  @@unique([companyId, sku])
}

// ============ FAKTURE ============

model Invoice {
  id            String   @id @default(cuid())
  companyId     String
  number        String
  date          DateTime @default(now())
  dueDate       DateTime
  partnerId     String
  status        String   @default("nacrt") // nacrt, poslata, placena, otkazana
  type          String   @default("izlazna") // izlazna, ulazna, predracun, avansna
  totalAmount   Float
  taxAmount     Float    @default(0)
  baseAmount    Float    @default(0) // osnovica (bez poreza)
  discountPct   Float    @default(0)
  currency      String   @default("RSD")
  exchangeRate  Float    @default(1)
  incoterms     String? // DAP, FOB, CIF, EXW, DDP...
  deliveryAddress String?
  advanceInvoiceId String? // za rate - parent avansna faktura
  installmentNumber Int? // koji deo rate (1,2,3...)
  totalInstallments Int? // ukupno rata
  fiscalizedNumber String? // fiskalni broj računa (Srbija)
  fiscalizedAt   DateTime?
  postedToJournal Boolean @default(false) // knjiženo u knjigovodstvo
  postedAt      DateTime?
  notes         String?
  paymentMethod String   @default("racun") // racun, gotovina, kartica
  sefStatus     String   @default("not_sent") // not_sent, sent, accepted, rejected
  sefSentAt     DateTime?
  sefUuid       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id])
  partner       Partner  @relation(fields: [partnerId], references: [id])
  items         InvoiceItem[]
  recurringId   String?
  recurring     RecurringInvoice? @relation(fields: [recurringId], references: [id])
  bankTransactions BankTransaction[]

  @@unique([companyId, number])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String
  productName String
  quantity    Float
  unitPrice   Float
  discountPct Float    @default(0)
  taxRate     Float    @default(20)
  total       Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ============ PONAVLJAjuCE FAKTURE ============

model RecurringInvoice {
  id              String       @id @default(cuid())
  companyId       String
  name            String
  partnerId       String
  frequency       String       // monthly, weekly, quarterly, yearly
  nextDate        DateTime     // when to generate next invoice
  lastGenerated   DateTime?
  startDate       DateTime     // when recurrence starts
  endDate         DateTime?    // optional end date
  isActive        Boolean      @default(true)
  items           String       // JSON array of invoice line items template
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  company         Company      @relation(fields: [companyId], references: [id])
  partner         Partner      @relation(fields: [partnerId], references: [id])
  invoices        Invoice[]
}

// ============ NABAVKA ============

model PurchaseOrder {
  id            String   @id @default(cuid())
  companyId     String
  number        String
  date          DateTime @default(now())
  partnerId     String
  status        String   @default("nacrt") // nacrt, poslata, primljena, otkazana
  totalAmount   Float
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id])
  partner       Partner  @relation(fields: [partnerId], references: [id])
  items         PurchaseOrderItem[]

  @@unique([companyId, number])
}

model PurchaseOrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Float
  unitPrice   Float
