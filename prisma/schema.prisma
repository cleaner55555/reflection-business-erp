generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ PARTNERI / KLIJENTI / DOBAVLJAČI ============

model Partner {
  id          String   @id @default(cuid())
  name        String
  pib         String   @unique
  maticniBr   String?
  address     String?
  city        String?
  zipCode     String?
  phone       String?
  email       String?
  type        String   @default("kupac") // kupac, dobavljac, partner
  account     String?
  bank        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoices         Invoice[]
  purchaseOrders   PurchaseOrder[]
  deliveryNotes    DeliveryNote[]
  contacts         Contact[]
  deals            Deal[]
  employees        Employee[]
  documents        Document[]
}

// ============ ROBA / PROIZVODI ============

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  barcode     String?
  category    String?
  unit        String   @default("kom") // kom, kg, l, m, pak
  purchasePrice Float
  sellingPrice  Float
  minStock    Int      @default(0)
  currentStock Int     @default(0)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoiceItems      InvoiceItem[]
  purchaseOrderItems PurchaseOrderItem[]
  stockMovements    StockMovement[]
  deliveryNoteItems DeliveryNoteItem[]
  priceListItems    PriceListItem[]
}

// ============ FAKTURE ============

model Invoice {
  id            String   @id @default(cuid())
  number        String   @unique
  date          DateTime @default(now())
  dueDate       DateTime
  partnerId     String
  status        String   @default("nacrt") // nacrt, poslata, placena, otkazana
  type          String   @default("izlazna") // izlazna, ulazna, predracun
  totalAmount   Float
  taxAmount     Float    @default(0)
  discountPct   Float    @default(0)
  notes         String?
  paymentMethod String   @default("racun") // racun, gotovina, kartica
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  partner Partner @relation(fields: [partnerId], references: [id])
  items   InvoiceItem[]
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String
  productName String
  quantity    Float
  unitPrice   Float
  discountPct Float    @default(0)
  taxRate     Float    @default(20)
  total       Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ============ NABAVKA ============

model PurchaseOrder {
  id            String   @id @default(cuid())
  number        String   @unique
  date          DateTime @default(now())
  partnerId     String
  status        String   @default("nacrt") // nacrt, poslata, primljena, otkazana
  totalAmount   Float
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  partner Partner @relation(fields: [partnerId], references: [id])
  items   PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Float
  unitPrice   Float
  total       Float

  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ============ MAGACIN / ZALIHE ============

model StockMovement {
  id          String   @id @default(cuid())
  productId   String
  date        DateTime @default(now())
  type        String   // prijem, izdavanje, inventura, korekcija
  quantity    Float
  documentRef String?
  notes       String?
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}

// ============ OTPREMNICE ============

model DeliveryNote {
  id            String   @id @default(cuid())
  number        String   @unique
  date          DateTime @default(now())
  partnerId     String
  status        String   @default("nacrt") // nacrt, pripremljena, otpremljena, stornirana
  invoiceNumber String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  partner Partner @relation(fields: [partnerId], references: [id])
  items   DeliveryNoteItem[]
}

model DeliveryNoteItem {
  id              String   @id @default(cuid())
  deliveryNoteId  String
  productId       String
  productName     String
  quantity        Float
  unitPrice       Float

  deliveryNote DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  product       Product @relation(fields: [productId], references: [id])
}

// ============ CENOVNICI ============

model PriceList {
  id          String   @id @default(cuid())
  name        String
  description String?
  validFrom   DateTime?
  validTo     DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items PriceListItem[]
}

model PriceListItem {
  id          String   @id @default(cuid())
  priceListId String
  productId   String
  price       Float
  discountPct Float    @default(0)

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
}

// ============ FINANSIJE ============

model Transaction {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  type          String   // prihod, rashod
  category      String   // promet, nabavka, plata, režije, ostalo
  amount        Float
  description   String
  documentRef   String?
  partnerId     String?
  createdAt     DateTime @default(now())
}

// ============ KASA ============

model CashRegister {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  type          String   // ulaz, izlaz
  amount        Float
  description   String
  partnerName   String?
  paymentMethod String   @default("gotovina")
  createdAt     DateTime @default(now())
}

// ============ CRM - KONTAKTI ============

model Contact {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  position    String?
  company     String?
  partnerId   String?
  notes       String?
  tags        String?
  isClient    Boolean  @default(false)
  isSupplier  Boolean  @default(false)
  isLead      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  partner     Partner?        @relation(fields: [partnerId], references: [id])
  activities  CrmActivity[]
  deals       Deal[]
}

// ============ CRM - POSLOVNE PRILIKE ============

model Deal {
  id          String   @id @default(cuid())
  title       String
  value       Float    @default(0)
  stage       String   @default("lead") // lead, kvalifikacija, predlog, pregovaranje, won, lost
  probability Int      @default(10)
  contactId   String?
  partnerId   String?
  assignedTo  String?
  closeDate   DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact     Contact?       @relation(fields: [contactId], references: [id])
  partner     Partner?       @relation(fields: [partnerId], references: [id])
  activities  CrmActivity[]
}

// ============ CRM - AKTIVNOSTI ============

model CrmActivity {
  id          String   @id @default(cuid())
  type        String   // poziv, sastanak, email, task, napomena
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean  @default(false)
  contactId   String?
  dealId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact     Contact? @relation(fields: [contactId], references: [id])
  deal        Deal?    @relation(fields: [dealId], references: [id])
}

// ============ KALENDAR ============

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  allDay      Boolean  @default(false)
  color       String   @default("primary")
  type        String   @default("sastanak")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============ PLATE I KADROVI ============

model Employee {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String?
  position      String?
  department    String?
  baseSalary    Float    @default(0)
  bankAccount   String?
  partnerId     String?  // ako je iznajmljen/vanradni
  isActive      Boolean  @default(true)
  hireDate      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  partner       Partner? @relation(fields: [partnerId], references: [id])
  payrolls      Payroll[]
  attendances   Attendance[]
}

model Payroll {
  id            String   @id @default(cuid())
  employeeId    String
  month         Int      // 1-12
  year          Int
  baseSalary    Float
  bonuses       Float    @default(0)
  deductions    Float    @default(0)
  netSalary     Float
  status        String   @default("nacrt") // nacrt, odobreno, isplaceno
  payDate       DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee      Employee @relation(fields: [employeeId], references: [id])
}

model Attendance {
  id            String   @id @default(cuid())
  employeeId    String
  date          DateTime
  hoursWorked   Float    @default(8)
  type          String   @default("rad") // rad, bolovanje, godisnji, sluzbeni_put, odsustvo
  notes         String?
  createdAt     DateTime @default(now())

  employee      Employee @relation(fields: [employeeId], references: [id])
}

// ============ OSNOVNA SREDSTVA ============

model Asset {
  id            String   @id @default(cuid())
  name          String
  category      String?
  serialNumber  String?
  purchaseDate  DateTime @default(now())
  purchasePrice Float
  currentValue  Float
  depreciation  Float    @default(0)
  usefulLife    Int      @default(60) // meseci
  location      String?
  status        String   @default("aktivno") // aktivno, na_popravci, izvan_upotrebe, prodato, otpisano
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============ PROJEKTI ============

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("aktivan") // aktivan, zavrsen, pauziran, otkazan
  startDate   DateTime @default(now())
  endDate     DateTime?
  budget      Float    @default(0)
  spent       Float    @default(0)
  priority    String   @default("srednji") // nizak, srednji, visok, hitan
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       ProjectTask[]
}

model ProjectTask {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      String   @default("todo") // todo, u_toku, zavrseno, blokirano
  priority    String   @default("srednji")
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============ DMS - DOKUMENTI ============

model Document {
  id          String   @id @default(cuid())
  title       String
  category    String?
  type        String?  // faktura, ugovor, ponuda, izvestaj, ostalo
  fileName    String?
  fileSize    Int      @default(0)
  status      String   @default("aktivno")
  partnerId   String?
  expiresAt   DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  partner     Partner? @relation(fields: [partnerId], references: [id])
}
