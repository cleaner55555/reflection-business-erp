  endDate     DateTime?
  budget      Float    @default(0)
  spent       Float    @default(0)
  priority    String   @default("srednji") // nizak, srednji, visok, hitan
  assignedTo  String?
  partnerId   String?
  tags        String?  // JSON array of tags
  color       String?  // hex color for project
  progress    Int      @default(0) // auto-calculated 0-100
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company       Company           @relation(fields: [companyId], references: [id])
  partner       Partner?          @relation(fields: [partnerId], references: [id])
  tasks         ProjectTask[]
  timesheetEntries TimesheetEntry[]
}

model ProjectTask {
  id             String    @id @default(cuid())
  companyId      String
  projectId      String
  title          String
  description    String?
  status         String    @default("todo") // todo, u_toku, zavrseno, blokirano
  priority       String    @default("srednji")
  dueDate        DateTime?
  assignedTo     String?
  estimatedHours Float     @default(0)
  loggedHours    Float     @default(0)
  orderNum       Int       @default(0)
  isBug          Boolean   @default(false) // bug tracking flag
  bugSeverity    String?   // critical, major, minor, trivial
  tags           String?   // JSON array of tags
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company       Company           @relation(fields: [companyId], references: [id])
  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timesheetEntries TimesheetEntry[]
}

// ============ TIMESHEET - EVIDENCIJA RADNOG VREMENA ============

model TimesheetEntry {
  id          String   @id @default(cuid())
  companyId   String
  projectId   String
  taskId      String
  employeeId  String?  // Ime zaposlenog (tekstualno za sada)
  date        DateTime @default(now())
  startTime   String   @default("")
  endTime     String   @default("")
  duration    Int      @default(0)   // minutes
  hours       Float    @default(0)
  status      String   @default("draft") // draft, submitted, approved, rejected
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company       Company     @relation(fields: [companyId], references: [id])
  project       Project     @relation(fields: [projectId], references: [id])
  task          ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ============ ZAPOSLENI - OCENE RADNOG UČINKA ============

model EmployeeEvaluation {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String
  period      String  // Q1, Q2, Q3, Q4, godisnje
  year        Int
  rating      Int     @default(3) // 1-5
  strengths   String?
  weaknesses  String?
  goals       String?
  reviewNotes String?
  reviewerId  String?
  status      String  @default("nacrt") // nacrt, zakazano, zavrseno
  reviewDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}

// ============ CRM - AUTOMATIZACIJA PRAVILA ============

model CrmAutomationRule {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  trigger     String  // stage_change, deal_created, days_inactive, score_above
  condition   String? // JSON: { field: value, ... }
  action      String  // move_stage, assign_to, send_email, add_tag, set_score
  actionData  String? // JSON: { to: "kvalifikacija", ... }
  isActive    Boolean  @default(true)
  executedCount Int   @default(0)
  lastExecutedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ============ KNJIGOVODSTVO - PORESKI PERIODI ============

model FiscalPeriod {
  id            String   @id @default(cuid())
  companyId     String
  year          Int
  month         Int
  status        String   @default("otvoren") // otvoren, zatvoren
  pdvSubmitted  Boolean  @default(false)
  pdvSubmittedAt DateTime?
  closedBy      String?
  closedAt      DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, year, month])
}

// ============ DMS - DOKUMENTI ============

model Document {
  id          String   @id @default(cuid())
  companyId   String
  title       String
  category    String?
  type        String?  // faktura, ugovor, ponuda, izvestaj, ostalo
  fileName    String?
  fileSize    Int      @default(0)
  status      String   @default("aktivno")
  partnerId   String?
  expiresAt   DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  partner Partner? @relation(fields: [partnerId], references: [id])
}

// ============ RENT A CAR ============

model RentalVehicle {
  id            String   @id @default(cuid())
  companyId     String
  name          String   // npr. VW Golf 8
  make          String
  model         String
  year          Int
  registration  String   // registarski broj
  fuelType      String   @default("dizel")
  transmission  String   @default("automatski") // automatski,manuelni
  seats         Int      @default(5)
  dailyRate     Float    // dnevna cena RSD
  weeklyRate    Float?
  monthlyRate   Float?
  mileage       Int      @default(0)
  status        String   @default("dostupno") // dostupno, iznajmljeno, na_servisu, rezervisano, prodato
  ac            Boolean  @default(true)
  gps           Boolean  @default(false)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  rentals Rental[]

  @@unique([companyId, registration])
}

model Rental {
  id            String   @id @default(cuid())
  companyId     String
  number        String
  vehicleId     String
  clientName    String
  clientPhone   String?
  clientEmail   String?
  clientIdDoc   String?  // broj lične karte
  startDate     DateTime
  endDate       DateTime
  pickupMileage Int
  returnMileage Int?
  dailyRate     Float
  totalDays     Int
  totalAmount   Float
  deposit       Float    @default(0)
  status        String   @default("rezervacija") // rezervacija, aktivna, zavrsena, otkazana
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id])
  vehicle RentalVehicle @relation(fields: [vehicleId], references: [id])

  @@unique([companyId, number])
}

// ============ KAFE RESTORAN ============

model RestoCategory {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  items   RestoMenuItem[]
}

model RestoMenuItem {
  id              String   @id @default(cuid())
  companyId       String
  categoryId      String
  categoryKey     String   @default("main_course")
  name            String
  description     String?
  price           Float
  cost            Float    @default(0)
  image           String?
  isAvailable     Boolean  @default(true)
  sortOrder       Int      @default(0)
  preparationTime Int      @default(0)
  calories        Int      @default(0)
  isVegetarian    Boolean  @default(false)
  isVegan         Boolean  @default(false)
  isGlutenFree    Boolean  @default(false)
  isSpicy         Boolean  @default(false)
  allergens       String   @default("[]")
  ingredients     String   @default("[]")
  rating          Float    @default(0)
  orderCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company    Company        @relation(fields: [companyId], references: [id])
  category   RestoCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems RestoOrderItem[]
}

model RestoTable {
  id          String   @id @default(cuid())
  companyId   String
  number      Int
  name        String?  // npr. "Terasa 1"
  capacity    Int      @default(4)
  status      String   @default("slobodan") // slobodan, zauzet, rezervisan
  location    String?  // npr. "sprat", "terasa", "bašta"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  orders  RestoOrder[]

  @@unique([companyId, number])
}

model RestoOrder {
  id            String   @id @default(cuid())
  companyId     String
  orderNumber   Int
  tableId       String?
  status        String   @default("u_toku") // u_toku, spremno, usluženo, plaćeno, otkazano
  type          String   @default("restoran") // restoran, porudzbina, dostava
  totalAmount   Float    @default(0)
  discountPct   Float    @default(0)
  waiter        String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id])
  table   RestoTable?   @relation(fields: [tableId], references: [id])
  items   RestoOrderItem[]
}

model RestoOrderItem {
  id            String   @id @default(cuid())
  companyId     String
  orderId       String
  menuItemId    String
  menuItemName  String
  quantity      Int
  unitPrice     Float
  total         Float
  notes         String?
  status        String   @default("naručeno") // naručeno, u_pripremi, spremno, usluženo

  company  Company      @relation(fields: [companyId], references: [id])
  order    RestoOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem RestoMenuItem @relation(fields: [menuItemId], references: [id])
}

// ============ MAILERLITE - EMAIL MARKETING ============

model EmailList {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company     Company          @relation(fields: [companyId], references: [id])
  subscribers EmailSubscriber[]
  campaigns   EmailCampaign[]
}

model EmailSubscriber {
  id            String   @id @default(cuid())
  companyId     String
  listId        String?
  email         String
  firstName     String?
  lastName      String?
  status        String   @default("aktivan") // aktivan, neaktivan, otkazan
  source        String?  // web forma, uvoz, ručno
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company    @relation(fields: [companyId], references: [id])
  list   EmailList?  @relation(fields: [listId], references: [id])
}

model EmailCampaign {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  subject       String
  preheader     String?
  content       String   // HTML sadržaj
  status        String   @default("nacrt") // nacrt, poslata, zakazana, u_toku, zavrsena
  listId        String?
  sentCount     Int      @default(0)
  openRate      Float    @default(0) // procenta
  clickRate     Float    @default(0)
  bounceRate    Float    @default(0)
  scheduledAt   DateTime?
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company   @relation(fields: [companyId], references: [id])
  list   EmailList? @relation(fields: [listId], references: [id])
}

model EmailTemplate {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  subject       String
  content       String   // HTML
  category      String?  // promotivno, transakciono, obavestenje
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ============ INTEGRACIJE ============

model IntegrationJob {
  id            String   @id @default(cuid())
  companyId     String
  type          String   // import, export
  entityType    String   // partners, products, transactions, contacts, invoices, stock
  source        String   @default("custom") // external_accounting_1, external_accounting_2, external_accounting_3, einvoice_system, custom
  status        String   @default("pending") // pending, processing, completed, failed, partial
  totalRows     Int      @default(0)
  successRows   Int      @default(0)
  failedRows    Int      @default(0)
  errors        String?  // JSON array of error details
  fileName      String?
  mapping       String?  // JSON: { sourceCol: targetField }
  options       String?  // JSON: skipDuplicates, updateExisting, etc.
  notes         String?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  creator User?  @relation("JobCreator", fields: [createdBy], references: [id])
}

// ============ SYNC CONNECTORS ============

model SyncConnector {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  type            String   // external_accounting_1, external_accounting_2, external_accounting_3, einvoice_system, enterprise_erp, custom_api
  direction       String   @default("import") // import, export, bidirectional
  isActive        Boolean  @default(false)
  status          String   @default("disconnected") // disconnected, connected, syncing, error
  hostUrl         String?
  apiKey          String?
  username        String?
  password        String?
  database        String?
  syncInterval    Int      @default(60) // minutes between auto-syncs
  syncEntities    String   // JSON array: ["partners","products"]
  fieldMapping    String?
  lastSyncAt      DateTime?
  lastSyncStatus  String?
  totalSyncs      Int      @default(0)
  totalRecords    Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company  @relation(fields: [companyId], references: [id])
  logs   SyncLog[]
}

model SyncLog {
  id              String   @id @default(cuid())
  companyId       String
  connectorId     String
  direction       String
  entityType      String
  status          String
  totalRecords    Int      @default(0)
  successRecords  Int      @default(0)
  failedRecords   Int      @default(0)
  errors          String?
  duration        Int      @default(0)
  triggerType     String   @default("auto")
  notes           String?
  createdAt       DateTime @default(now())

  company   Company      @relation(fields: [companyId], references: [id])
  connector SyncConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
}

// ============ NOTIFICATIONS ============

model Notification {
  id          String   @id @default(cuid())
  companyId   String
  userId      String?  // null = broadcast to all users in company
  type        String   // overdue_invoice, low_stock, payment_received, task_due, system
  title       String
  message     String
  entityType  String?  // invoice, product, partner, etc.
  entityId    String?
  isRead      Boolean  @default(false)
  priority    String   @default("medium") // low, medium, high, urgent
  actionUrl   String?  // which module to open (e.g., "fakture")
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
}

// ============ BANKA - SINHRONIZACIJA I PREKNJIŽAVANJE ============

model BankAccount {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  bank          String?
  account       String
  currency      String   @default("RSD")
  isActive      Boolean  @default(true)
  balance       Float    @default(0)
  lastSyncAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company      Company          @relation(fields: [companyId], references: [id])
  transactions BankTransaction[]
}

model BankTransaction {
  id            String   @id @default(cuid())
  companyId     String
  bankAccountId String
  date          DateTime
  amount        Float
  description   String
  reference     String?
  counterpart   String?
  category      String?
  isReconciled  Boolean  @default(false)
  invoiceId     String?
  transactionId String?
  createdAt     DateTime @default(now())

  company     Company      @relation(fields: [companyId], references: [id])
  bankAccount BankAccount  @relation(fields: [bankAccountId], references: [id])
  invoice     Invoice?     @relation(fields: [invoiceId], references: [id])
}

// ============ SETTINGS ============

model AppSetting {
  id          String   @id @default(cuid())
  companyId   String?
  key         String
  label       String?
  value       String
  type        String   @default("text") // text, boolean, number, json
  group       String   @default("general") // general, modules, company
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id])

  @@unique([companyId, key])
}

// ============ AUDIT LOG - DNEVNIK IZMENA ============

model AuditLog {
  id          String   @id @default(cuid())
  companyId   String
  userId      String?
  action      String   // create, update, delete, login, logout, export, import
  entity      String   // invoice, partner, product, journal_entry, etc.
  entityId    String?
  details     String?  // JSON: { field: oldValue → newValue, ... }
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([entity])
  @@index([createdAt])
}

// ============ WEBHOOKS - EVENT DRIVEN INTEGRACIJE ============

model Webhook {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  url         String
  events      String   // JSON: ["invoice.created","partner.updated",...]
  secret      String?  // for HMAC signature
  headers     String?  // JSON: { "Authorization": "Bearer ..." }
  isActive    Boolean  @default(true)
  lastTriggerAt  DateTime?
  successCount   Int      @default(0)
  failCount      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ============ POS - MALOPRODAJA ============

model POSShift {
  id              String   @id @default(cuid())
  companyId       String
  number          Int      // shift number for the day
  cashierName     String   // who opened the shift
  status          String   @default("otvorena") // otvorena, zatvorena
  openingBalance  Float    @default(0)
  closingBalance  Float?   // calculated when closed
  expectedCash    Float?   // opening + cash sales
  difference      Float?   // closing - expected
  openedAt        DateTime @default(now())
  closedAt        DateTime?
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company   @relation(fields: [companyId], references: [id])
  orders  POSOrder[]
}

model POSOrder {
  id              String   @id @default(cuid())
  companyId       String
  shiftId         String
  orderNumber     String   // POS-YYMMDD-NNN
  partnerId       String?  // optional customer
  partnerName     String?  // denormalized for speed
  status          String   @default("aktivan") // aktivan, placen, storniran
  paymentMethod   String   @default("gotovina") // gotovina, kartica, transakcioni_racun, virmanski
  subtotal        Float    @default(0) // without tax
  taxAmount       Float    @default(0)
  discountAmount  Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  changeAmount    Float    @default(0)
  itemsCount      Int      @default(0)
  fiscalized      Boolean  @default(false)
  fiscalNumber    String?
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company    @relation("POSOrderCompany", fields: [companyId], references: [id])
  shift   POSShift   @relation(fields: [shiftId], references: [id])
  partner Partner?   @relation("POSOrderPartner", fields: [partnerId], references: [id])
  lines   POSOrderLine[]
}

model POSOrderLine {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  productName String
  sku         String?
  quantity    Float
  unitPrice   Float
  discountPct Float    @default(0)
  taxRate     Float    @default(20)
  total       Float    // (quantity * unitPrice * (1 - discountPct/100))

  order   POSOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id])
}


// ============ SHIPPING & LOGISTICS ============

model ShippingCarrier {
  id            String   @id @default(cuid())
  companyId     String
  name          String   // npr. "BEX", "Post Express", "DHL"
  code          String   // npr. "bex", "post-express", "dhl"
  type          String   @default("domestic") // domestic, regional, international
  website       String?
  apiUrl        String?
  apiKey        String?
  apiSecret     String?
  contactPhone  String?
  contactEmail  String?
  isActive      Boolean  @default(true)
  defaultWeight Float    @default(0.5) // default paket tezina u kg
  defaultPrice  Float    @default(0) // default cena
  deliveryEstimate String @default("1-3") // dana
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company          @relation(fields: [companyId], references: [id])
  orders        ShippingOrder[]
}

model ShippingOrder {
  id              String   @id @default(cuid())
  companyId       String
  number          String   // npr. "SHP-250715-001"
  carrierId       String?
  partnerId       String?
  deliveryNoteId  String?
  invoiceId       String?
  status          String   @default("nacrt") // nacrt, cekanje_preuzimanja, preuzeto, u_tranzitu, isporuceno, vraceno, otkazano
  weight          Float    @default(0) // kg
  volume          Float    @default(0) // m3
  packageCount    Int      @default(1)
  declaredValue   Float    @default(0)
  shippingCost    Float    @default(0)
  codAmount       Float    @default(0) // pouzeće
  codCurrency     String   @default("RSD")
  insurance       Boolean  @default(false)
  insuranceCost   Float    @default(0)

  // Adresa pošiljaoca
  senderName      String?
  senderAddress   String?
  senderCity      String?
  senderZip       String?
  senderPhone     String?

  // Adresa primaoca
  recipientName   String?
  recipientAddress String?
  recipientCity   String?
  recipientZip    String?
  recipientPhone  String?
  recipientEmail  String?

  // Reference
  refNumber       String? // referentni broj za kurira
  trackingNumber  String? // tracking broj od kurira
  labelUrl        String? // URL štampanog labela

  pickedUpAt      DateTime?
  inTransitAt     DateTime?
  deliveredAt     DateTime?
  returnedAt      DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company       Company          @relation(fields: [companyId], references: [id])
  carrier       ShippingCarrier? @relation(fields: [carrierId], references: [id])
  partner       Partner?         @relation("ShippingPartner", fields: [partnerId], references: [id])
  events        ShippingEvent[]

  @@unique([companyId, number])
}

model ShippingEvent {
  id            String   @id @default(cuid())
  companyId     String
  orderId       String
  status        String   // picked_up, in_transit, at_hub, out_for_delivery, delivered, failed, returned
  location      String?
  description   String?
  eventDate     DateTime @default(now())
  rawResponse   String?  // JSON from carrier API
  createdAt     DateTime @default(now())

  company       Company        @relation(fields: [companyId], references: [id])
  order         ShippingOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}


// =============================================
// Faza 8-9: NOVI MODULI (full feature set)
// =============================================

// ============ SALES / PONUDE ============

model SalesOrder {
  id            String   @id @default(cuid())
  companyId     String
  number        String
  date          DateTime @default(now())
  partnerId     String
  status        String   @default("nacrt") // nacrt, poslata, potvrdena, otkazana
  totalAmount   Float
  taxAmount     Float    @default(0)
  discountPct   Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id])
  partner       Partner        @relation(fields: [partnerId], references: [id])
  lines         SalesOrderLine[]

  @@unique([companyId, number])
}

model SalesOrderLine {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Float
  unitPrice   Float
  discountPct Float    @default(0)
  taxRate     Float    @default(20)
