{
  "name": "Reflection ERP — Enterprise Business Platform",
  "short_name": "Reflection",
  "description": "Najkompletnija ERP/CRM platforma — 127+ modula, 391 API endpointa, multi-tenant SaaS, real-time, PWA. Kompletno poslovanje u jednom aplikaciji.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "any",
  "background_color": "#ffffff",
  "theme_color": "#09090b",
  "id": "/",
  "lang": "sr",
